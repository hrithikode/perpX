generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid()) @db.Uuid()
  name     String
  email    String  @unique
  password String
  Asset    Asset[]
  order    Order[]
}

model Asset {
  id       Int    @id @default(autoincrement())
  symbol   Symbol
  balance  Int
  decimals Int    @default(2)
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, symbol], name: "user_symbol_unique")
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  side          Side
  symbol        Symbol
  qty           Int
  qtyDecimals   Int         @default(8)
  openingPrice  Int
  priceDecimals Int         @default(4)
  margin        Int
  status        OrderStatus
  leverage      Int         @default(1)
  createdAt     DateTime    @default(now())
  closedAt      DateTime?
  User          User        @relation(fields: [userId], references: [id])
}

enum Symbol {
  USDT
  BTC
}

enum Side {
  long
  short
}

enum OrderStatus {
  open
  closed
}
